# Zoho OAuth2 Self Client credentials
# Register at https://api-console.zoho.com — choose "Self Client"
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Zoho Sheet
ZOHO_SHEET_ID=
ZOHO_SHEET_NAME=Sheet1

# Zoho WorkDrive folder IDs (get from WorkDrive URL)
WORKDRIVE_INCOMING_FOLDER_ID=
WORKDRIVE_PROCESSED_FOLDER_ID=
WORKDRIVE_FAILED_FOLDER_ID=

# Optional: webhook secret for Zoho Flow verification
WEBHOOK_SECRET=
